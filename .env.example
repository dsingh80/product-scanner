# Application
DEBUG=false
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# URL / fetch settings
MAX_URL_LENGTH=2048
FETCH_TIMEOUT_MS=30000
MAX_EXTRACT_CHARS=12000

# LLM provider: auto (anthropic → openai fallback) | openai | anthropic
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Playwright
PLAYWRIGHT_HEADLESS=true
