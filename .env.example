# Application
DEBUG=false
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# URL / fetch settings
MAX_URL_LENGTH=2048
FETCH_TIMEOUT_MS=30000
MAX_EXTRACT_CHARS=12000

# LLM provider: auto (anthropic → openai fallback) | openai | anthropic
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Playwright
PLAYWRIGHT_HEADLESS=true

# Reverse proxy (set true when behind Nginx/Caddy so per-IP rate limits work)
TRUST_PROXY_HEADERS=false

# Rate limiting
RATE_LIMIT_PER_HOUR=60

# Concurrency (max simultaneous LLM pipeline calls)
MAX_CONCURRENT_ANALYZE=2

# Logging (set LOG_DIR to enable rotating file logs; empty = stdout only)
LOG_DIR=/app/logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
